{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/server",
  "framework": "vite",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_PUBLISHABLE_KEY": "@supabase_publishable_key"
  },
  "functions": {
    "api/[...].js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ]
}
